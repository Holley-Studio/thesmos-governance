{
  "name": "thesmos-governance",
  "version": "2.0.0",
  "project": "thesmos-governance",
  "tier": "premium",
  "power": "lean",
  "disabledRules": [
    "direct_env_access",
    "eval_usage",
    "vibe_eval_usage",
    "lic_proprietary_dependency",
    "lic_copyleft_dependency",
    "mcp_cursor_rules_injection",
    "mcp_readme_injection",
    "mcp_cursor_rules_external_url",
    "mcp_tool_description_injection"
  ],
  "reviewIgnorePaths": [
    "thesmos/rules/",
    "extensions/vscode/dist/"
  ],
  "ignoredFolders": [
    "node_modules",
    ".git",
    "dist",
    "out",
    ".next",
    ".vercel",
    ".claude",
    ".thesmos",
    ".cursor",
    "coverage",
    "pantheon",
    "downloads"
  ],
  "largeFileThreshold": 800,
  "failOnSeverity": [
    "BLOCKER"
  ],
  "warnOnSeverity": [
    "HIGH"
  ],
  "severityRules": [
    { "category": "ai_output_used_as_command",    "severity": "BLOCKER" },
    { "category": "hardcoded_credentials",         "severity": "BLOCKER" },
    { "category": "secret_in_diff",                "severity": "BLOCKER" },
    { "category": "child_process_shell_injection", "severity": "BLOCKER" },
    { "category": "ssrf_fetch",                    "severity": "BLOCKER" },
    { "category": "path_traversal",                "severity": "BLOCKER" },
    { "category": "sql_injection",                 "severity": "BLOCKER" },
    { "category": "shell_injection",               "severity": "BLOCKER" },
    { "category": "vibe_ssrf",                     "severity": "BLOCKER" },
    { "category": "vibe_sql_template_injection",   "severity": "BLOCKER" },
    { "category": "vibe_path_traversal",           "severity": "BLOCKER" },
    { "category": "ssrf_unvalidated_url",          "severity": "BLOCKER" },
    { "category": "missing_api_auth",              "severity": "HIGH"    },
    { "category": "missing_ts_extension",          "severity": "LOW"     },
    { "category": "n_plus_one_query",              "severity": "LOW"     },
    { "category": "log_in_tight_loop",             "severity": "LOW"     },
    { "category": "floating_promise",              "severity": "MEDIUM"  },
    { "category": "sync_fs_in_handler",            "severity": "MEDIUM"  }
  ],
  "routing": {
    "mode": "auto",
    "councilConfirmThreshold": 4
  },
  "context1M": {
    "allow1M": false
  },
  "tokenBudget": {
    "enabled": true,
    "sessionMaxTokens": 2000000,
    "sessionMaxCostUSD": 15,
    "dailyMaxCostUSD": 75,
    "projectMaxCostUSD": 1000,
    "alertAt": 0.8,
    "hardStopAt": 1.0
  }
}
