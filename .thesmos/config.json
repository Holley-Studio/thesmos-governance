{
  "name": "thesmos-governance",
  "version": "2.0.0",
  "project": "thesmos-governance",
  "disabledRules": [
    "direct_env_access",
    "eval_usage",
    "vibe_eval_usage",
    "lic_proprietary_dependency",
    "lic_copyleft_dependency",
    "mcp_cursor_rules_injection",
    "mcp_readme_injection",
    "mcp_cursor_rules_external_url",
    "mcp_tool_description_injection",
    "eu_ai_high_risk_no_conformity",
    "eu_ai_prohibited_biometric",
    "eu_ai_no_risk_management_system",
    "eu_ai_training_data_governance_missing",
    "eu_ai_no_technical_documentation",
    "eu_ai_no_decision_audit_log",
    "eu_ai_no_human_oversight",
    "hipaa_phi_unencrypted_at_rest",
    "hipaa_phi_no_tls",
    "hipaa_phi_no_access_control",
    "hipaa_phi_no_audit_log",
    "hipaa_phi_minimum_necessary_missing",
    "hipaa_phi_to_llm_no_baa",
    "hipaa_phi_session_no_timeout",
    "dora_incident_classification_missing",
    "dora_third_party_ict_no_register",
    "dora_resilience_testing_missing",
    "dora_rto_undocumented",
    "dora_threat_intel_sharing_missing",
    "gdpr_dpia_missing_high_risk",
    "gdpr_pii_in_logs_external",
    "rag_vector_store_public_write",
    "agent_cross_agent_auth_missing",
    "agent_consent_lifecycle_missing",
    "agent_dpia_missing",
    "vibe_hardcoded_secret",
    "dast_eval_user_input"
  ],
  "ignoredFolders": [
    "node_modules",
    ".git",
    "dist",
    "out",
    ".next",
    ".vercel",
    ".claude",
    ".thesmos",
    ".cursor",
    "coverage"
  ],
  "largeFileThreshold": 800,
  "failOnSeverity": ["BLOCKER"],
  "warnOnSeverity": ["HIGH"],
  "severityRules": [
    { "category": "ai_output_used_as_command", "severity": "HIGH" },
    { "category": "missing_ts_extension", "severity": "LOW" },
    { "category": "n_plus_one_query", "severity": "LOW" },
    { "category": "log_in_tight_loop", "severity": "LOW" },
    { "category": "floating_promise", "severity": "MEDIUM" },
    { "category": "hardcoded_credentials", "severity": "HIGH" },
    { "category": "secret_in_diff", "severity": "HIGH" },
    { "category": "child_process_shell_injection", "severity": "HIGH" },
    { "category": "ssrf_fetch", "severity": "HIGH" },
    { "category": "ssrf_unvalidated_url", "severity": "HIGH" },
    { "category": "path_traversal", "severity": "HIGH" },
    { "category": "sql_injection", "severity": "HIGH" },
    { "category": "shell_injection", "severity": "HIGH" },
    { "category": "vibe_ssrf", "severity": "HIGH" },
    { "category": "vibe_sql_template_injection", "severity": "HIGH" },
    { "category": "vibe_path_traversal", "severity": "HIGH" },
    { "category": "sync_fs_in_handler", "severity": "MEDIUM" },
    { "category": "missing_api_auth", "severity": "HIGH" }
  ]
}
