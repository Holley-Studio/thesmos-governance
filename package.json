{
  "name": "thesmos-helper",
  "private": true,
  "license": "FSL-1.1-MIT",
  "description": "Monorepo for thesmos-governance: npm package, GitHub Action, and VS Code extension.",
  "scripts": {
    "build": "npm run build --workspace=thesmos && npm run build --workspace=actions/pr-review && npm run build --workspace=extensions/vscode",
    "build:lib": "npm run build --workspace=thesmos",
    "build:action": "npm run build --workspace=actions/pr-review",
    "build:ext": "npm run build --workspace=extensions/vscode",
    "typecheck": "npm run typecheck --workspace=thesmos && npm run typecheck --workspace=actions/pr-review && npm run typecheck --workspace=extensions/vscode",
    "test": "npm test --workspace=thesmos",
    "thesmos:scan": "tsx thesmos/bin/cli.ts scan",
    "thesmos:ci-check": "tsx thesmos/bin/cli.ts ci-check",
    "thesmos:review": "tsx thesmos/bin/cli.ts review",
    "thesmos:validate": "tsx thesmos/bin/cli.ts validate",
    "thesmos:doctor": "tsx thesmos/bin/cli.ts doctor",
    "thesmos:audit": "tsx thesmos/bin/cli.ts audit",
    "thesmos:adapters": "tsx thesmos/bin/cli.ts adapters",
    "agents:install:local": "npm run agents:install:local --workspace=thesmos",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build:lib && changeset publish",
    "hooks:install": "git config core.hooksPath .githooks",
    "backup:now": "bash scripts/backup-to-drive.sh",
    "backup:status": "tail -20 .git/thesmos-backup.log",
    "backup:restore": "bash scripts/restore-from-drive.sh"
  },
  "workspaces": [
    "thesmos",
    "actions/pr-review",
    "extensions/vscode"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10"
  }
}
