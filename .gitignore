# Dependencies
node_modules/

# Next.js / general build output
.next/
out/
build/
.tmp-pack/

# Claude Code local (per-machine) settings — shared settings.json IS committed
.claude/settings.local.json

# macOS
.DS_Store
**/.DS_Store

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Thesmos runtime artifacts (append-only usage log — per-machine, never committed)
.thesmos/token-usage.jsonl
# One-time upgrade ack — written by loadConfig on first run after severity merge fix
.thesmos/.severity-fix-ack

# Editor
.idea/

# Test coverage
coverage/

# TypeScript project build info (generated by tsc --build)
*.tsbuildinfo

# NOTE: actions/pr-review/dist/ and extensions/vscode/dist/ ARE committed.
# GitHub Actions requires dist/index.js to be present in the repo at run time.
# VS Code extension dist is committed so no build step is required for development.
.vercel

# VS Code extension build artifacts (packaged .vsix files)
extensions/vscode/*.vsix

# Thesmos session runtime artifacts (per-machine)
.thesmos/agent-activity.jsonl
.thesmos/token-session-id
.thesmos/active-plan.md

# Nested dogfood governance tree + generated adapters inside the package —
# regenerable via `thesmos init && thesmos adapters` from thesmos/; the
# canonical governance tree lives at the repo root.
thesmos/.thesmos/
thesmos/CLAUDE.md
thesmos/AGENTS.md
thesmos/GEMINI.md

# Paid Pantheon bundles — sold via Gumroad, not distributed from the public
# repo. Only the free starter pack is committed. package-agents.ts writes
# these to dist-packs/ (also gitignored) for local upload to Gumroad.
website/downloads/thesmos-pantheon-agents.zip
website/downloads/thesmos-pantheon-founders.zip
website/downloads/thesmos-pantheon-agencies.zip
dist-packs/

# Paid Pantheon raw exports — same policy as the bundles above (split-at-HEAD,
# 2026-07-03): the full 67-agent per-platform export tree is paid product,
# delivered via the Gumroad packs. Only the 5 free starter agents (the files
# the website links directly) + the free GPT Store listing stay tracked.
# The files remain on disk locally for pack builds; they are untracked in git.
pantheon/exports/**
!pantheon/exports/*/
!pantheon/exports/starters/**
!pantheon/exports/README.md
!pantheon/exports/chatgpt/pantheon-council-free-gpt-store.txt
!pantheon/exports/chatgpt/zeus-executive-agent-chatgpt.txt
!pantheon/exports/chatgpt/athena-strategy-agent-chatgpt.txt
!pantheon/exports/chatgpt/argus-security-agent-chatgpt.txt
!pantheon/exports/chatgpt/apollo-content-agent-chatgpt.txt
!pantheon/exports/chatgpt/hephaestus-design-agent-chatgpt.txt
# ChatGPT's 8,000-char Instructions limit means each free god above is paired
# with a "-knowledge.txt" companion (uploaded as Knowledge, not pasted) —
# those need to stay tracked too, or the website's direct-download links 404.
!pantheon/exports/chatgpt/zeus-executive-agent-chatgpt-knowledge.txt
!pantheon/exports/chatgpt/athena-strategy-agent-chatgpt-knowledge.txt
!pantheon/exports/chatgpt/argus-security-agent-chatgpt-knowledge.txt
!pantheon/exports/chatgpt/apollo-content-agent-chatgpt-knowledge.txt
!pantheon/exports/chatgpt/hephaestus-design-agent-chatgpt-knowledge.txt
!pantheon/exports/claude-code/zeus-executive-agent.md
!pantheon/exports/claude-code/athena-strategy-agent.md
!pantheon/exports/claude-code/argus-security-agent.md
!pantheon/exports/claude-code/apollo-content-agent.md
!pantheon/exports/claude-code/hephaestus-design-agent.md
!pantheon/exports/cursor/zeus-executive-agent.mdc
!pantheon/exports/cursor/athena-strategy-agent.mdc
!pantheon/exports/cursor/argus-security-agent.mdc
!pantheon/exports/cursor/apollo-content-agent.mdc
!pantheon/exports/cursor/hephaestus-design-agent.mdc
!pantheon/exports/gemini/zeus-executive-agent-gemini.txt
!pantheon/exports/gemini/athena-strategy-agent-gemini.txt
!pantheon/exports/gemini/argus-security-agent-gemini.txt
!pantheon/exports/gemini/apollo-content-agent-gemini.txt
!pantheon/exports/gemini/hephaestus-design-agent-gemini.txt

# Google Drive backup — rclone config lives outside the repo by design
# (~/.config/rclone/rclone.conf), never inside it. These entries are
# defense-in-depth only. See docs/backup-recovery.md.
rclone.conf
*.credentials.json
