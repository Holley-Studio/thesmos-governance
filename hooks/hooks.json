{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "npx thesmos-governance claude:govern check" }]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "npx thesmos-governance claude:govern check" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "npx thesmos-governance claude:govern check" }]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [{ "type": "command", "command": "npx thesmos-governance claude:govern budget-check" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "npx thesmos-governance drift --quiet 2>&1 || true" }]
      }
    ]
  }
}
