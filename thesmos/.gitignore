# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
dist/
*.js.map

# ── Consumer artifacts ────────────────────────────────────────────────────────
# Thesmos generates these files in CONSUMER repos, not in the library itself.
# Running `thesmos:init` or `thesmos:adapters` during local development
# writes these into the working directory. They must never be committed here.
#
# Rule: The thesmos/ directory is the PRODUCER. These files belong in repos
# that depend on Thesmos, not in the Thesmos source tree.

.thesmos/
CLAUDE.md
GEMINI.md
AGENTS.md
.cursor/rules/thesmos.mdc
.codex/thesmos.md
.github/copilot-instructions.md
.github/workflows/thesmos-review.yml

# ── Test temp artifacts ───────────────────────────────────────────────────────
# Some tests write to tmp/ subdirs inside the repo as a fallback. Ignore them.
tmp/
*.tmp

# ── TypeScript build output ───────────────────────────────────────────────────
tsconfig.tsbuildinfo
